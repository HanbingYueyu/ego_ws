<?xml version="1.0"?>
<robot name="ackermann_4w_laser" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Simplified 4-wheel Ackermann-like model: front axle steering + rear drive helper wheel. -->

  <xacro:property name="wheel_r" value="0.17"/>
  <xacro:property name="wheel_w" value="0.08"/>
  <xacro:property name="track" value="0.62"/>
  <xacro:property name="wheelbase" value="0.86"/>

  <link name="base_link"/>

  <link name="chassis">
    <visual>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry>
        <box size="1.18 0.72 0.16"/>
      </geometry>
      <material name="chassis_blue">
        <color rgba="0.08 0.20 0.78 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry>
        <box size="1.18 0.72 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <mass value="22.0"/>
      <inertia ixx="1.35" ixy="0" ixz="0" iyy="3.10" iyz="0" izz="3.70"/>
    </inertial>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="front_axle">
    <visual>
      <geometry>
        <box size="0.10 ${track} 0.05"/>
      </geometry>
      <material name="dark">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.10 ${track} 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="front_steering_joint" type="fixed">
    <parent link="chassis"/>
    <child link="front_axle"/>
    <origin xyz="${wheelbase/2.0} 0 ${wheel_r}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_r}" length="${wheel_w}"/>
        </geometry>
        <material name="wheel_black">
          <color rgba="0.05 0.05 0.05 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_r}" length="${wheel_w}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.2"/>
        <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.010" iyz="0" izz="0.010"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:wheel_link name="front_left_wheel"/>
  <xacro:wheel_link name="front_right_wheel"/>
  <xacro:wheel_link name="rear_left_wheel"/>
  <xacro:wheel_link name="rear_right_wheel"/>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_axle"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 ${track/2.0} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_axle"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 ${-track/2.0} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_left_wheel"/>
    <origin xyz="${-wheelbase/2.0} ${track/2.0} ${wheel_r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_right_wheel"/>
    <origin xyz="${-wheelbase/2.0} ${-track/2.0} ${wheel_r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <!-- Hidden helper wheel lets tricycle plugin provide robust propulsion with cmd_vel. -->
  <link name="drive_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.001" length="0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_r}" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <joint name="drive_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="drive_wheel"/>
    <origin xyz="${-wheelbase/2.0} 0 ${wheel_r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <joint name="hokuyo_joint" type="fixed">
    <parent link="base_link"/>
    <child link="hokuyo_link"/>
    <origin xyz="0.30 0 0.52" rpy="0 0 0"/>
  </joint>

  <link name="hokuyo_link">
    <visual>
      <geometry><box size="0.08 0.08 0.05"/></geometry>
      <material name="laser_blue"><color rgba="0.20 0.70 0.95 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.08 0.08 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <gazebo reference="chassis">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="front_left_wheel"><mu1>1.6</mu1><mu2>1.6</mu2><kp>500000</kp><kd>1.0</kd></gazebo>
  <gazebo reference="front_right_wheel"><mu1>1.6</mu1><mu2>1.6</mu2><kp>500000</kp><kd>1.0</kd></gazebo>
  <gazebo reference="rear_left_wheel"><mu1>1.8</mu1><mu2>1.8</mu2><kp>500000</kp><kd>1.0</kd></gazebo>
  <gazebo reference="rear_right_wheel"><mu1>1.8</mu1><mu2>1.8</mu2><kp>500000</kp><kd>1.0</kd></gazebo>
  <gazebo reference="drive_wheel"><mu1>2.0</mu1><mu2>2.0</mu2><kp>500000</kp><kd>1.0</kd></gazebo>

  <gazebo>
    <plugin name="front_left_wheel_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <jointName>front_left_wheel_joint</jointName>
      <updateRate>40.0</updateRate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="front_right_wheel_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <jointName>front_right_wheel_joint</jointName>
      <updateRate>40.0</updateRate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="rear_left_wheel_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <jointName>rear_left_wheel_joint</jointName>
      <updateRate>40.0</updateRate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="rear_right_wheel_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <jointName>rear_right_wheel_joint</jointName>
      <updateRate>40.0</updateRate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="drive_wheel_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <robotNamespace>/</robotNamespace>
      <jointName>drive_wheel_joint</jointName>
      <updateRate>40.0</updateRate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="ackermann_4w_drive" filename="libgazebo_ros_planar_move.so">
      <robotNamespace>/</robotNamespace>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
      <publishTF>true</publishTF>
      <odometryRate>40.0</odometryRate>
    </plugin>
  </gazebo>

  <gazebo reference="hokuyo_link">
    <material>Gazebo/Black</material>
    <sensor type="ray" name="hokuyo_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-2.26889</min_angle>
            <max_angle>2.26889</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>25.0</max>
        </range>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>hokuyo_link</frameName>
      </plugin>
    </sensor>
  </gazebo>
</robot>
