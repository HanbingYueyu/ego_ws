<launch>
  <!-- EGO-Planner + ground robot (odom on /odom, 2D lidar as PointCloud in world frame) -->
  <arg name="map_size_x" value="120.0"/>
  <arg name="map_size_y" value="80.0"/>
  <arg name="map_size_z" value="6.0"/>

  <arg name="odom_topic" default="/odom"/>
  <arg name="grid_map_cloud" default="/scan_cloud_world"/>
  <arg name="flight_type" default="1"/>
  <arg name="point_num" default="5"/>
  <arg name="point0_x" default="-15.0"/>
  <arg name="point0_y" default="0.0"/>
  <arg name="point0_z" default="0.25"/>
  <arg name="point1_x" default="0.0"/>
  <arg name="point1_y" default="15.0"/>
  <arg name="point1_z" default="0.25"/>
  <arg name="point2_x" default="15.0"/>
  <arg name="point2_y" default="0.0"/>
  <arg name="point2_z" default="0.25"/>
  <arg name="point3_x" default="0.0"/>
  <arg name="point3_y" default="-15.0"/>
  <arg name="point3_z" default="0.25"/>
  <arg name="point4_x" default="-15.0"/>
  <arg name="point4_y" default="0.0"/>
  <arg name="point4_z" default="0.25"/>

  <include file="$(find ego_planner)/launch/advanced_param.xml">

    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    <arg name="odometry_topic" value="$(arg odom_topic)"/>

    <arg name="camera_pose_topic" value="/pcl_render_node/camera_pose"/>
    <arg name="depth_topic" value="/pcl_render_node/depth"/>

    <arg name="cloud_topic" value="/camera/depth/points"/>
    <arg name="grid_map_cloud" value="$(arg grid_map_cloud)"/>

    <arg name="cx" value="321.04638671875"/>
    <arg name="cy" value="243.44969177246094"/>
    <arg name="fx" value="387.229248046875"/>
    <arg name="fy" value="387.229248046875"/>

    <arg name="max_vel" value="0.9" />
    <arg name="max_acc" value="1.0" />

    <arg name="planning_horizon" value="7.5" />

    <arg name="flight_type" value="$(arg flight_type)" />
    <arg name="point_num" value="$(arg point_num)" />

    <!-- Waypoints on ground plane (z ~ chassis height for planner consistency) -->
    <arg name="point0_x" value="$(arg point0_x)" />
    <arg name="point0_y" value="$(arg point0_y)" />
    <arg name="point0_z" value="$(arg point0_z)" />

    <arg name="point1_x" value="$(arg point1_x)" />
    <arg name="point1_y" value="$(arg point1_y)" />
    <arg name="point1_z" value="$(arg point1_z)" />

    <arg name="point2_x" value="$(arg point2_x)" />
    <arg name="point2_y" value="$(arg point2_y)" />
    <arg name="point2_z" value="$(arg point2_z)" />

    <arg name="point3_x" value="$(arg point3_x)" />
    <arg name="point3_y" value="$(arg point3_y)" />
    <arg name="point3_z" value="$(arg point3_z)" />

    <arg name="point4_x" value="$(arg point4_x)" />
    <arg name="point4_y" value="$(arg point4_y)" />
    <arg name="point4_z" value="$(arg point4_z)" />

  </include>

  <!-- advanced_param.xml only assigns waypoint0/1; set waypoint2~4 explicitly for ackermann case -->
  <param name="/ego_planner_node/fsm/waypoint2_x" value="$(arg point2_x)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint2_y" value="$(arg point2_y)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint2_z" value="$(arg point2_z)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint3_x" value="$(arg point3_x)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint3_y" value="$(arg point3_y)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint3_z" value="$(arg point3_z)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint4_x" value="$(arg point4_x)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint4_y" value="$(arg point4_y)" type="double"/>
  <param name="/ego_planner_node/fsm/waypoint4_z" value="$(arg point4_z)" type="double"/>
  <param name="/ego_planner_node/fsm/replan_sync_with_odom" value="true"/>
  <param name="/ego_planner_node/fsm/replan_odom_err_thresh" value="0.55"/>
  <param name="/ego_planner_node/fsm/goal_reach_odom_thresh" value="0.45"/>
  <param name="/ego_planner_node/fsm/reanchor_global_traj_on_detour" value="true"/>
  <param name="/ego_planner_node/fsm/global_reanchor_dist_thresh" value="1.10"/>
  <param name="/ego_planner_node/manager/lock_ground_z" value="true"/>

  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="planning/pos_cmd"/>

    <remap from="/odom_world" to="$(arg odom_topic)"/>
    <param name="traj_server/time_forward" value="1.0" type="double"/>
  </node>

  <node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator" output="screen">
    <remap from="~odom" to="$(arg odom_topic)"/>
    <remap from="~goal" to="/move_base_simple/goal"/>
    <remap from="~traj_start_trigger" to="/traj_start_trigger" />
    <param name="waypoint_type" value="manual-lonely-waypoint"/>
  </node>

</launch>
