<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="point_num" default="5"/>
  <arg name="point0_x" default="-15.0"/>
  <arg name="point0_y" default="0.0"/>
  <arg name="point0_z" default="0.25"/>
  <arg name="point1_x" default="0.0"/>
  <arg name="point1_y" default="15.0"/>
  <arg name="point1_z" default="0.25"/>
  <arg name="point2_x" default="15.0"/>
  <arg name="point2_y" default="0.0"/>
  <arg name="point2_z" default="0.25"/>
  <arg name="point3_x" default="0.0"/>
  <arg name="point3_y" default="-15.0"/>
  <arg name="point3_z" default="0.25"/>
  <arg name="point4_x" default="-15.0"/>
  <arg name="point4_y" default="0.0"/>
  <arg name="point4_z" default="0.25"/>
  <param name="use_sim_time" value="$(arg use_sim_time)"/>
  <env name="GAZEBO_PLUGIN_PATH" value=""/>
  <env name="GAZEBO_MODEL_PATH" value=""/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="true"/>
    <arg name="recording" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <param name="robot_description" command="$(find xacro)/xacro $(find ackermann_ego_gazebo)/urdf/tricycle_with_laser.xacro"/>

  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen">
    <param name="publish_frequency" type="double" value="30.0"/>
  </node>

  <node name="spawn_tricycle" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-urdf -model tricycle -param robot_description -x 0 -y 0 -z 0.15 -Y 0"/>

  <node pkg="tf2_ros" type="static_transform_publisher" name="world_odom" args="0 0 0 0 0 0 world odom"/>

  <node pkg="ackermann_ego_gazebo" type="random_obstacles.py" name="random_obstacles" output="screen"/>
  <node pkg="ackermann_ego_gazebo" type="odom_car_marker.py" name="odom_car_marker" output="screen">
    <remap from="/odom" to="/tricycle/odom"/>
  </node>
  <node pkg="ackermann_ego_gazebo" type="laserscan_cloud_world.py" name="laserscan_cloud_world" output="screen">
    <param name="cloud_out" value="/scan_cloud_world"/>
  </node>
  <node pkg="ackermann_ego_gazebo" type="ego_car_controller.py" name="ego_car_controller" output="screen">
    <remap from="/odom" to="/tricycle/odom"/>
    <remap from="/cmd_vel" to="/tricycle/cmd_vel"/>
  </node>

  <include file="$(find ego_planner)/launch/run_in_ackermann_sim.launch">
    <arg name="odom_topic" value="/tricycle/odom"/>
    <arg name="grid_map_cloud" value="/scan_cloud_world"/>
    <arg name="point_num" value="$(arg point_num)"/>
    <arg name="point0_x" value="$(arg point0_x)"/>
    <arg name="point0_y" value="$(arg point0_y)"/>
    <arg name="point0_z" value="$(arg point0_z)"/>
    <arg name="point1_x" value="$(arg point1_x)"/>
    <arg name="point1_y" value="$(arg point1_y)"/>
    <arg name="point1_z" value="$(arg point1_z)"/>
    <arg name="point2_x" value="$(arg point2_x)"/>
    <arg name="point2_y" value="$(arg point2_y)"/>
    <arg name="point2_z" value="$(arg point2_z)"/>
    <arg name="point3_x" value="$(arg point3_x)"/>
    <arg name="point3_y" value="$(arg point3_y)"/>
    <arg name="point3_z" value="$(arg point3_z)"/>
    <arg name="point4_x" value="$(arg point4_x)"/>
    <arg name="point4_y" value="$(arg point4_y)"/>
    <arg name="point4_z" value="$(arg point4_z)"/>
  </include>

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find ackermann_ego_gazebo)/rviz/ackermann_car.rviz" output="screen"/>
</launch>
